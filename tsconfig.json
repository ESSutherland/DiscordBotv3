{
  "compilerOptions": {
      "jsx": "react",
      "target": "ES2022",
      "module": "CommonJS",
      "moduleResolution": "Node",
      "strict": true,
      "noImplicitAny": true,
      "declaration": false,
      "skipLibCheck": true,
      "strictNullChecks": true,
      "resolveJsonModule": true,
      "outDir": "dist",
      "esModuleInterop": true,
      "ignoreDeprecations": "6.0"
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}